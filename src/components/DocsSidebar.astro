---
const { currentPath } = Astro.props;

const sections = [
  {
    title: 'Getting Started',
    items: [
      { label: 'Introduction', href: '/docs' },
    ]
  },
  {
    title: 'Reference',
    items: [
      { label: 'Commands', href: '/docs/commands' },
      { label: 'Spec Format v0.2', href: '/docs/spec-format' },
      { label: 'Framework Coverage', href: '/docs/frameworks' },
    ]
  },
  {
    title: 'Guides',
    items: [
      { label: 'CI Integration', href: '/docs/ci' },
      { label: 'Troubleshooting', href: '/docs/troubleshooting' },
    ]
  }
];
---

<nav class="w-60 shrink-0 border-r border-gray-800 overflow-y-auto py-6 px-4 hidden md:block">
  <a href="/" class="text-lg font-bold gradient-text font-mono mb-6 block">pecto</a>
  {sections.map(section => (
    <div class="mb-6">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2 px-2">{section.title}</h3>
      <ul class="space-y-0.5">
        {section.items.map(item => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block px-2 py-1.5 rounded text-sm transition',
                currentPath === item.href
                  ? 'bg-[#E185C8]/10 text-[#E185C8] font-medium'
                  : 'text-gray-400 hover:text-white hover:bg-gray-800/50'
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
  <div class="mt-8 pt-4 border-t border-gray-800">
    <a href="https://github.com/pecto-dev/pecto" class="text-xs text-gray-500 hover:text-white transition px-2">GitHub</a>
  </div>
</nav>
