---
import Layout from '../layouts/Layout.astro';
import DocsSidebar from './DocsSidebar.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/docs';
---

<Layout title={`${title} — pecto docs`} description={description}>
  <!-- Mobile nav -->
  <div class="md:hidden fixed top-0 w-full z-50 bg-gray-950/90 backdrop-blur-sm border-b border-gray-800 px-4 h-14 flex items-center justify-between">
    <a href="/" class="text-lg font-bold gradient-text font-mono">pecto</a>
    <a href="/docs" class="text-sm text-gray-400">Docs</a>
  </div>

  <div class="flex min-h-screen md:pt-0 pt-14">
    <DocsSidebar currentPath={currentPath} />

    <main class="flex-1 overflow-y-auto">
      <div class="max-w-3xl mx-auto px-6 py-12">
        <h1 class="font-heading text-3xl font-bold mb-2">{title}</h1>
        {description && <p class="text-gray-400 mb-8">{description}</p>}

        <div class="prose">
          <slot />
        </div>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  /* Prose styling for docs content */
  .prose h2 { font-family: 'Public Sans', system-ui, sans-serif; font-size: 1.5rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 0.75rem; color: #e2e8f0; }
  .prose h3 { font-family: 'Public Sans', system-ui, sans-serif; font-size: 1.125rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.5rem; color: #cbd5e1; }
  .prose p { color: #94a3b8; line-height: 1.75; margin-bottom: 1rem; }
  .prose ul { color: #94a3b8; list-style: disc; padding-left: 1.5rem; margin-bottom: 1rem; }
  .prose ol { color: #94a3b8; list-style: decimal; padding-left: 1.5rem; margin-bottom: 1rem; }
  .prose li { margin-bottom: 0.25rem; line-height: 1.7; }
  .prose code { background: #1e293b; color: #e2e8f0; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875rem; }
  .prose pre { background: #0f172a; border: 1px solid #1e293b; border-radius: 0.5rem; padding: 1rem 1.25rem; overflow-x: auto; margin-bottom: 1.5rem; }
  .prose pre code { background: none; padding: 0; font-size: 0.8125rem; line-height: 1.7; }
  .prose a { color: #E185C8; text-decoration: none; }
  .prose a:hover { text-decoration: underline; }
  .prose table { width: 100%; border-collapse: collapse; margin-bottom: 0.75rem; font-size: 0.875rem; }
  .prose th { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #334155; color: #94a3b8; font-weight: 600; }
  .prose td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #1e293b; color: #94a3b8; }
  .prose blockquote { border-left: 3px solid #334155; padding-left: 1rem; color: #64748b; margin-bottom: 1rem; }
  .prose hr { border-color: #1e293b; margin: 2rem 0; }
</style>
